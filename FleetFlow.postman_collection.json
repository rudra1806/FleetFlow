                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "vehicles"
                            ],
                            "query": [
                                {
                                    "key": "page",
                                    "value": "1"
                                },
                                {
                                    "key": "limit",
                                    "value": "10"
                                },
                                {
                                    "key": "type",
                                    "value": "",
                                    "disabled": true
                                },
                                {
                                    "key": "status",
                                    "value": "",
                                    "disabled": true
