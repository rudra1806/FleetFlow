                {
                    "name": "Update Vehicle",
                    "request": {
                        "method": "PUT",
                        "url": "{{baseUrl}}/api/vehicles/:id",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"Truck Alpha Updated\",\n  \"currentOdometer\": 15000\n}"
                        }
                    }
                },
                {
                    "name": "Update Vehicle Status",
                    "request": {
                        "method": "PATCH",
                        "url": "{{baseUrl}}/api/vehicles/:id/status",
                        "header": [
