                            "raw": "{\n  \"name\": \"Truck Alpha\",\n  \"model\": \"Tata LPT 3521\",\n  \"licensePlate\": \"GJ01AB1234\",\n  \"type\": \"truck\",\n  \"maxCapacity\": 5000,\n  \"currentOdometer\": 12500,\n  \"fuelType\": \"diesel\",\n  \"acquisitionCost\": 1500000,\n  \"year\": 2022,\n  \"color\": \"White\",\n  \"region\": \"Gujarat\"\n}"
